apiVersion: argoproj.io/v1alpha1
kind: AppProject
metadata:
  name: root-bootstrap
  namespace: argocd
  labels:
    app.kubernetes.io/name: argocd
    app.kubernetes.io/instance: ${CLUSTER_NAME}
    app.kubernetes.io/component: project
    app.kubernetes.io/part-of: ${CLUSTER_NAME}
    app.kubernetes.io/managed-by: bootstrap
spec:
  description: Bootstrap scope for root app-of-apps
  sourceRepos:
    - ${REPO_URL}
  destinations:
    - namespace: argocd
      server: https://kubernetes.default.svc
    # ConfigMap kyverno/cluster-config is shipped via the top-level
    # overlay (kubernetes/overlays/homelab/infrastructure/platform-network-interface/
    # kustomization.yaml). Until that resource moves into the
    # platform-network-interface Application's own source, root-bootstrap
    # must be allowed to deploy into the kyverno namespace.
    - namespace: kyverno
      server: https://kubernetes.default.svc
  clusterResourceWhitelist:
    - group: ""
      kind: Namespace
  namespaceResourceWhitelist:
    - group: argoproj.io
      kind: AppProject
    - group: argoproj.io
      kind: Application
    # ConfigMap needed for kyverno/cluster-config (see destinations note).
    - group: ""
      kind: ConfigMap
